{
	"name": "@neiforfaen/i18n",
	"version": "0.0.0",
	"type": "module",
	"private": true,
	"scripts": {
		"lint": "biome check",
		"format": "biome check --write",
		"typecheck": "tsc --noEmit",
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"build": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --emit-ts-declarations",
		"machine-translate": "inlang machine translate --project project.inlang"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "^2.18.1",
		"@inlang/cli": "^3.0.0",
		"typescript": "6.0.3"
	},
	"exports": {
		"./messages": "./src/paraglide/messages.js",
		"./runtime": "./src/paraglide/runtime.js"
	}
}
