{
	"$schema": "https://turbo.build/schema.json",
	"ui": "stream",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**", "src/paraglide/**"]
		},
		"clean": {
			"dependsOn": ["^clean"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"format": {
			"dependsOn": ["^format"]
		},
		"typecheck": {
			"dependsOn": ["build", "^typecheck"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
