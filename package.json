{
	"name": "neiforfaen",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"lint": "turbo lint",
		"clean": "turbo clean && rm -rf pnpm-lock.yaml node_modules .turbo",
